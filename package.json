{
  "name": "porterman",
  "version": "0.0.2",
  "description": "Porterman is a helper tool designed to support your workflow and help you move toward your goals with MahameruJS.",
  "main": "./dist/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepare": "npm run build"
  },
  "keywords": [
    "mahamerujs",
    "porterman",
    "utility",
    "helper",
    "tool",
    "typescript"
  ],
  "author": "Bintan <hello@bintvn.co>",
  "license": "ISC",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./string-helper": {
      "types": "./dist/string-helper.d.ts",
      "default": "./dist/string-helper.js"
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}