{
	"compilerOptions": {
		"target": "ESNext",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"rootDir": "./src",
		"outDir": "./dist",
		"declaration": true,
		"resolveJsonModule": true,
		"types": [
			"node"
		]
	},
	"include": [
		"./src/**/*.ts",
	],
	"exclude": [
		"./node_modules",
		"./dist"
	]
}